# ─────────────────────────────────────────────────────────────────────────────
# API Gateway — example configuration (Phase 1)
#
# Copy to `.env` and adjust, then just run the gateway — it AUTO-LOADS `.env`
# from the working directory on startup:
#
#     cp .env.example .env
#     ./gateway
#
# Use a different path with GATEWAY_ENV_FILE=/path/to/file. Real environment
# variables take precedence over this file. (You can still `set -a; source .env;
# set +a` if you prefer loading it into your shell.)
#
# Every value below shows its DEFAULT; uncomment and change what you need.
# (In Phase 2, routes/policies move into the SQLite config store and the admin
#  UI; only secrets, ports, and the DB path will remain env vars.)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Public listen address for proxied traffic.
GATEWAY_PROXY_ADDR=:8080

# HTTP server timeouts (Go duration syntax: 500ms, 15s, 2m, 1h).
GATEWAY_READ_TIMEOUT=15s
GATEWAY_WRITE_TIMEOUT=30s
GATEWAY_IDLE_TIMEOUT=60s

# Max time to drain in-flight requests on SIGINT/SIGTERM before exiting.
GATEWAY_SHUTDOWN_TIMEOUT=15s

# ── Observability ────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
GATEWAY_LOG_LEVEL=info

# Path where Prometheus metrics are exposed.
GATEWAY_METRICS_PATH=/metrics

# ── Credentials (secrets) ────────────────────────────────────────────────────
# HMAC secret for validating Bearer JWTs (HS256/384/512). Leave empty to
# disable JWT auth. In production, inject from a secrets manager — never commit.
# CHANGE THIS — generate one with: openssl rand -hex 32
GATEWAY_JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of accepted API keys (sent by clients as `X-API-Key`).
# Leave empty to disable API-key auth. CHANGE THESE.
GATEWAY_API_KEYS=example-key-change-me

# ── Rate limiting defaults ───────────────────────────────────────────────────
# Applied to any route that does not specify its own `rate_limit`.
# Sustained requests/second per client IP, and the burst bucket size.
GATEWAY_RATE_LIMIT_RPS=100
GATEWAY_RATE_LIMIT_BURST=200

# ── Trusted proxies (client-IP resolution) ───────────────────────────────────
# Comma-separated CIDRs/IPs of upstream proxies whose X-Forwarded-For header is
# trusted. Empty = trust none, so XFF is IGNORED and the peer's RemoteAddr is
# used (prevents clients spoofing XFF to evade per-IP rate limits). Set this to
# your edge LB / ingress network when running behind one, e.g. 10.0.0.0/8.
GATEWAY_TRUSTED_PROXIES=

# ── Upstream transport timeouts ──────────────────────────────────────────────
GATEWAY_UPSTREAM_DIAL_TIMEOUT=10s
GATEWAY_UPSTREAM_RESPONSE_TIMEOUT=30s

# ── Routes ───────────────────────────────────────────────────────────────────
# A JSON array of route objects. Must be ONE LINE for `source` to work.
# Fields:
#   name         label used in logs & metrics
#   path_prefix  matched against the request path (longest match wins, required)
#   upstream     backend base URL — scheme + host required (required)
#   strip_prefix remove path_prefix before forwarding upstream
#   methods      optional HTTP method allow-list, e.g. ["GET","POST"]
#   auth         { require_auth: bool, methods: ["jwt","api_key"] }  (empty methods = any)
#   rate_limit   { algorithm, rps, burst, window_sec }
#                  algorithm: token_bucket (default) | leaky_bucket |
#                             fixed_window | sliding_window
#                  rps:        sustained requests/sec (<= 0 disables limiting)
#                  burst:      bucket capacity (token_bucket / leaky_bucket)
#                  window_sec: window length for the *_window algorithms
#                              (default 1); per-window limit = rps × window_sec
#
# Example: a protected API and a public endpoint.
# NOTE: value is wrapped in single quotes so `source` preserves the JSON quotes.
GATEWAY_ROUTES='[{"name":"users","path_prefix":"/api/users","upstream":"http://localhost:9001","strip_prefix":true,"auth":{"require_auth":true,"methods":["jwt","api_key"]},"rate_limit":{"algorithm":"token_bucket","rps":100,"burst":200}},{"name":"public","path_prefix":"/public","upstream":"http://localhost:9002","strip_prefix":false}]'

# The same GATEWAY_ROUTES value, pretty-printed for reference (NOT loaded — the
# active value is the single-line one above):
#
# [
#   {
#     "name": "users",
#     "path_prefix": "/api/users",
#     "upstream": "http://localhost:9001",
#     "strip_prefix": true,
#     "auth":       { "require_auth": true, "methods": ["jwt", "api_key"] },
#     "rate_limit": { "algorithm": "token_bucket", "rps": 100, "burst": 200 }
#   },
#   {
#     "name": "public",
#     "path_prefix": "/public",
#     "upstream": "http://localhost:9002",
#     "strip_prefix": false
#   }
# ]
